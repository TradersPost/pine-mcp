{
  "name": "pinescript-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Pine Script v6 documentation - search, reference lookup, guides, and examples",
  "type": "module",
  "bin": {
    "pinescript-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "data/manual/**/*.md",
    "data/docs/**/*.md",
    "data/reference/language-reference.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "pinescript",
    "pine-script",
    "tradingview",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
