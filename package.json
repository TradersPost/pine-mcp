{
  "name": "pinescript-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for Pine Script v6 documentation - search, reference lookup, guides, and examples",
  "type": "module",
  "bin": {
    "pinescript-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "data/manual/**/*.md",
    "data/docs/**/*.md",
    "data/reference/language-reference.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "node dist/index.js --check",
    "scrape-guide": "tsx scripts/scrape-guide.ts",
    "scrape-reference": "tsx scripts/scrape-reference.ts",
    "update-data": "bash scripts/update-data.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "pinescript",
    "pine-script",
    "tradingview",
    "model-context-protocol"
  ],
  "author": "TradersPost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TradersPost/pine-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/TradersPost/pine-mcp/issues"
  },
  "homepage": "https://github.com/TradersPost/pine-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "puppeteer": "^24.38.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
